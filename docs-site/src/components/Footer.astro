---
const year = new Date().getFullYear();

const columns = [
  {
    title: "Product",
    links: [
      { label: "Documentation", href: "/llmrouter/docs/" },
      { label: "GitHub", href: "https://github.com/elloloop/llmrouter" },
      { label: "Releases", href: "https://github.com/elloloop/llmrouter/releases" },
      { label: "pkg.go.dev", href: "https://pkg.go.dev/github.com/elloloop/llmrouter" },
    ],
  },
  {
    title: "Providers",
    links: [
      { label: "OpenAI", href: "/llmrouter/docs/providers/openai/" },
      { label: "Anthropic", href: "/llmrouter/docs/providers/anthropic/" },
      { label: "OpenAI-compatible", href: "/llmrouter/docs/providers/openai-compatible/" },
    ],
  },
  {
    title: "Community",
    links: [
      { label: "Issues", href: "https://github.com/elloloop/llmrouter/issues" },
      { label: "Discussions", href: "https://github.com/elloloop/llmrouter/discussions" },
      { label: "Discussions", href: "https://github.com/elloloop/llmrouter/discussions" },
    ],
  },
];
---

<footer
  class="mt-24 border-t border-border bg-muted/20 px-6 py-12 text-sm md:px-10"
>
  <div class="mx-auto grid max-w-6xl gap-10 sm:grid-cols-2 md:grid-cols-4">
    <div class="space-y-3">
      <a
        href="/llmrouter/"
        class="flex items-center gap-2 font-bold"
      >
        <div
          class="h-6 w-6 rounded-md bg-gradient-to-br from-primary to-primary/60"
        >
        </div>
        <span class="text-primary">llmrouter</span>
      </a>
      <p class="text-xs text-muted-foreground leading-relaxed">
        Streaming-first Go client for LLM providers. One OpenAI-shaped API
        for OpenAI, Anthropic, and any OpenAI-compatible endpoint.
      </p>
      <p class="text-xs text-muted-foreground">© {year} llmrouter</p>
    </div>
    {
      columns.map((col) => (
        <div>
          <h4 class="mb-3 text-xs font-semibold uppercase tracking-wider text-foreground">
            {col.title}
          </h4>
          <ul class="space-y-2">
            {col.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-muted-foreground transition-colors hover:text-foreground"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
  <div
    class="mx-auto mt-10 flex max-w-6xl flex-col items-center justify-between gap-4 border-t border-border pt-6 text-xs text-muted-foreground sm:flex-row"
  >
    <p>© {year} llmrouter</p>
    <ul class="flex items-center gap-5">
      <li>
        <a href="https://github.com/elloloop/llmrouter" class="transition-colors hover:text-foreground">GitHub</a>
      </li>
      <li>
        <a href="https://github.com/elloloop/llmrouter/releases" class="transition-colors hover:text-foreground">Releases</a>
      </li>
    </ul>
  </div>
</footer>
